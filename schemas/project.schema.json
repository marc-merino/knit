{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knit project",
  "type": "object",
  "required": ["schemaVersion", "kind", "id", "createdAt", "updatedAt", "repos"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "kind": { "const": "KnitProject" },
    "id": { "type": "string" },
    "repos": { "type": "array" },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "repos": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cwd": { "type": "string" },
          "command": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
