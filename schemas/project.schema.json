{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knit project",
  "type": "object",
  "required": ["schemaVersion", "kind", "id", "createdAt", "updatedAt", "repos"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "kind": { "const": "KnitProject" },
    "id": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "repos": { "type": "array" },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "repos": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cwd": { "type": "string" },
          "command": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "stackRepo": { "type": "string" },
        "composeFile": { "type": "string" },
        "profilePath": { "type": "string" },
        "projectConfigFile": { "type": "string" },
        "database": {
          "type": "object",
          "properties": {
            "mode": { "enum": ["shared", "bundle"] },
            "host": { "type": "string" },
            "port": { "type": "integer" },
            "name": { "type": "string" },
            "nameTemplate": { "type": "string" },
            "portBase": { "type": "integer" },
            "startCommand": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          },
          "additionalProperties": false
        },
        "ports": {
          "type": "object",
          "properties": {
            "backendBase": { "type": "integer" },
            "frontendBase": { "type": "integer" },
            "step": { "type": "integer" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "landing": {
      "type": "object",
      "properties": {
        "provider": { "enum": ["github"] },
        "merge": {
          "type": "object",
          "properties": {
            "repoOrder": {
              "type": "array",
              "items": { "type": "string" }
            },
            "needs": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "includeUnlisted": { "type": "boolean" },
            "method": { "enum": ["squash", "merge", "rebase"], "default": "merge" },
            "waitForChecks": { "type": "boolean" },
            "requiredChecksOnly": { "type": "boolean" },
            "deleteBranch": { "type": "boolean" },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "intervalSeconds": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "deployments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "anyOf": [
              { "required": ["repoId"] },
              { "required": ["repo"] }
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "repoId": { "type": "string" },
              "repo": { "type": "string" },
              "mode": { "enum": ["command", "push"] },
              "needs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "checkout": {
                "type": "object",
                "required": ["branch"],
                "properties": {
                  "branch": { "type": "string", "minLength": 1 },
                  "remote": { "type": "string" },
                  "update": { "enum": ["fetch", "pull", "none"] }
                },
                "additionalProperties": false
              },
              "cwd": { "type": "string" },
              "command": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
